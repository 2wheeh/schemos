{
  "name": "schemos",
  "version": "0.2.0",
  "type": "module",
  "description": "Type-safe CosmWasm contract interactions, zero codegen",
  "license": "MIT",
  "author": "wnhlee <2wheeh@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/2wheeh/schemos"
  },
  "keywords": [
    "cosmwasm",
    "cosmos",
    "type-safe",
    "json-schema",
    "typescript",
    "wasm",
    "smart-contracts"
  ],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schemas": {
      "source": "./src/schemas/index.ts",
      "import": "./dist/schemas/index.js",
      "types": "./dist/schemas/index.d.ts"
    },
    "./telescope": {
      "source": "./src/adapters/telescope.ts",
      "import": "./dist/adapters/telescope.js",
      "types": "./dist/adapters/telescope.d.ts"
    }
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.js",
        "types": "./dist/index.d.ts"
      },
      "./schemas": {
        "import": "./dist/schemas/index.js",
        "types": "./dist/schemas/index.d.ts"
      },
      "./telescope": {
        "import": "./dist/adapters/telescope.js",
        "types": "./dist/adapters/telescope.d.ts"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:types": "TYPES=true vitest run",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "json-schema-to-ts": "^3.1.1"
  },
  "devDependencies": {
    "@ark/attest": "^0.56.0",
    "@cosmjs/amino": "^0.38.1",
    "@cosmjs/cosmwasm-stargate": "^0.38.1",
    "@interchainjs/types": "^1.21.0",
    "@interchain-kit/react": "^0.10.1",
    "@types/node": "^24.0.0",
    "interchainjs": "^1.21.0",
    "typescript": "catalog:",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.30.3"
}
