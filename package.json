{
  "name": "cosmore",
  "version": "0.0.1",
  "type": "module",
  "description": "Type-safe CosmWasm contract interactions, zero codegen",
  "license": "MIT",
  "author": "Wonhee Lee",
  "keywords": [
    "cosmwasm",
    "cosmos",
    "type-safe",
    "json-schema",
    "typescript",
    "wasm",
    "smart-contracts"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:types": "TYPES=true vitest run",
    "check": "biome check --write",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "ajv": "^8.17.0"
  },
  "devDependencies": {
    "@ark/attest": "^0.56.0",
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "json-schema-to-ts": "^3.1.0",
    "typescript": "~5.8.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
