{
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "wnhlee <2wheeh@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/2wheeh/schemos"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "pnpm --filter schemos build",
    "typecheck": "pnpm --filter schemos typecheck",
    "test": "pnpm --filter schemos test",
    "test:types": "pnpm --filter schemos test:types",
    "test:e2e": "pnpm --filter schemos test:e2e",
    "check": "biome check --write",
    "check-ci": "pnpm build && pnpm typecheck",
    "site:dev": "pnpm --filter site dev",
    "site:build": "pnpm --filter site build",
    "site:preview": "pnpm --filter site preview",
    "release": "pnpm build && changeset publish",
    "bump": "taze -r -w && pnpm install",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "husky": "^9.1.7",
    "taze": "^19.9.2"
  }
}
